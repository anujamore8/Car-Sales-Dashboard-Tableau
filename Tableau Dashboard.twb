      <column caption='YTD Total Sales' datatype='integer' default-format='c&quot; $&quot;#,##0,,.00M;&quot; $&quot;-#,##0,,.00M' name='[Calculation_2025088649035776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF  &#13;&#10;YEAR([Date]) = {FIXED : MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
      <column caption='YOY Sales Growth' datatype='real' name='[Calculation_2025088652062722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2025088649035776] - [YTD Total Sales (copy)_2025088651767809])&#13;&#10;/ [YTD Total Sales (copy)_2025088651767809]' />
      </column>
      <column caption='YTD Cars Sold' datatype='integer' default-format='c&quot;#&quot;#,##0,.00K' name='[Calculation_2025088673738755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF  &#13;&#10;YEAR([Date]) = {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END )' />
      </column>
      <column caption='YOY Cars Sold Growth' datatype='real' default-format='p0.00%' name='[Calculation_2025088674217989]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2025088673738755] - [YTD Cars Sold (copy)_2025088674111492])&#13;&#10; / [YTD Cars Sold (copy)_2025088674111492]' />
      </column>
      <column caption='YTD Avg price' datatype='real' default-format='c&quot;$&quot;#,##0,.00K' name='[Calculation_2025088691281927]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2025088649035776] / [Calculation_2025088673738755]' />
      </column>
      <column caption='PYTD Avg price' datatype='real' name='[Calculation_2025088691544072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD Total Sales (copy)_2025088651767809] / [YTD Cars Sold (copy)_2025088674111492]' />
      </column>
      <column caption='YOY Avg Growth' datatype='real' name='[Calculation_2025088691720201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2025088691281927] - [Calculation_2025088691544072])&#13;&#10;/[Calculation_2025088691544072]' />
